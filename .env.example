# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
SERVER_PORT=3001

# Your production domain (no trailing slash)
FRONTEND_URL=https://yourdomain.com

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_HEX_STRING

# ─── Admin account (first-run seed only) ──────────────────────────────────────
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── SMTP (for password-reset emails) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=you@gmail.com
SMTP_FROM_NAME=KeepMailing

# ─── Stripe (required for paid plan upgrades in production) ──────────────────
STRIPE_SECRET_KEY=CHANGE_ME_YOUR_STRIPE_SECRET_KEY
